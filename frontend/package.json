{
  "name": "lcpsocialnetwork",
  "version": "1.0.0",
  "description": "lcp social network",
  "main": "index.js",
  "scripts": {
    "server": "node index.js",
    "server_api": "cd ..\\backend\\API\\aspnetcore\\lcpsnapi && dotnet run",
    "start": "set NODE_ENV=development & webpack-dev-server --config webpack.dev.js --open",
    "start_prod": "set NODE_ENV=production & webpack serve --config webpack.prod.js --open",
    "build": "set NODE_ENV=production & webpack --config webpack.prod.js",
    "start_all": "concurrently \"npm run server\" \"npm run server_api\" \"npm run start\"",
    "start_all_p": "concurrently \"npm run server\" \"npm run server_api\" \"npm run start_prod\"",
    "build_all": "concurrently \"npm run server\" \"npm run server_api\" \"npm run build\"",
    "rem_dist": "rd /s /q dist",
    "rem_dist_n_do_build": "rd /s /q dist & npm run build",
    "rem_n_ins_nm": "rd /s /q node_modules & del /f package-lock.json & npm install"
  },
  "private": true,
  "keywords": [],
  "author": "Luis Carvalho (luiscarvalho239@gmail.com)",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.8",
    "css-loader": "^6.7.1",
    "css-minimizer-webpack-plugin": "^4.0.0",
    "ejs-loader": "^0.5.0",
    "file-loader": "^6.2.0",
    "html-loader": "^4.1.0",
    "html-webpack-plugin": "^5.5.0",
    "mini-css-extract-plugin": "^2.6.1",
    "node-sass": "^7.0.3",
    "postcss-loader": "^7.0.1",
    "sass": "^1.54.4",
    "sass-loader": "^13.0.2",
    "style-loader": "^3.3.1",
    "ts-loader": "^9.4.2",
    "typescript": "^4.9.4",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.10.0",
    "webpack-dev-server": "^4.10.0",
    "webpack-merge": "^5.8.0"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.5",
    "bootstrap": "^5.2.0",
    "bootstrap-icons": "^1.9.1",
    "clean-webpack-plugin": "^4.0.0",
    "concurrently": "^7.3.0",
    "ejs": "^3.1.8"
  }
}
