<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= htmlWebpackPlugin.options.title %></title>
    <link rel="shortcut icon" href="/assets/icons/favicon.ico" type="image/x-icon">
</head>
<body id="login" class="theme">
    <div class="container max-container">
        <div class="row">
            <div class="col-12 col-md-6 order-2 order-sm-2 order-md-1 order-lg-1 order-xl-1 order-xxl-1 p-0 colm1">
                <h1>LCP Social Network</h1>
                <div class="foot_links">
                    <p class="mb-3">Created by <a href="mailto:luiscarvalho239@gmail.com">Luigi Carvalho</a> - &copy;<%= htmlWebpackPlugin.options.year %> - LCP</p>
                    <a href="pages/privacy_policy.html">Privacy Policy</a>
                    <a href="pages/about.html" class="ms-2">About</a>
                    <a href="pages/terms_of_service.html" class="ms-2">Terms of Service</a>
                </div>
            </div>
            <div class="col-12 col-md-6 order-1 order-sm-1 order-md-2 order-lg-2 order-xl-2 order-xxl-2 p-3 colm2">
                <h3>Login</h3>
                
                <form method="get" class="formlog mt-3" id="formlog">
                    <div class="form-group mt-3" data-required="true">
                        <label for="username">Username</label>
                        <input type="text" name="username" id="username" class="form-control username" />
                    </div>
                    <div class="form-group mt-3" data-required="true">
                        <label for="password">Password</label>
                        <input type="password" name="password" id="password" class="form-control password" />
                    </div>
                    <div class="form-group mt-3 me-auto ms-auto text-center">
                        <div class="reqmsg mt-3 mb-3" id="reqmsg"></div>
                        <div class="forgetac mt-3" id="forgetac">
                            <p>Did you forget your account? Please <b><a href="pages/reset_account.html">click here</a></b> to reset your account.</p>
                        </div>
                        <input type="reset" class="btn btn-secondary btnclear ms-1" value="Clear" />
                        <input type="submit" class="btn btn-primary btnenter" value="Enter" />
                    </div>
                </form>
                
                <a href="pages/register.html" class="btn btn-primary mt-3">Register</a>
                <a href="pages/main.html" class="btn btn-primary mt-3">Enter without login</a>
            </div>
            <div class="clearfix"></div>
        </div>
    </div>
</body>
</html>